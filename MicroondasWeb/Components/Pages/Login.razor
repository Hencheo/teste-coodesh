@page "/login"
@using System.Text.Json
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthService Auth
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Login - Micro-ondas</PageTitle>

<div class="login-outer-container">
    <div class="login-container">
        <div class="visor-login">
            <div class="status-tela">@mensagemStatus</div>
        </div>

        <div class="painel-login">
            <div class="form-grupo">
                <label>Usuário:</label>
                <input type="text" @bind="usuario" class="form-control" placeholder="admin" />
            </div>

            <div class="form-grupo">
                <label>Senha:</label>
                <input type="password" @bind="senha" class="form-control" placeholder="admin" />
            </div>

            <div class="acoes-login">
                <button @onclick="RealizarLogin" class="btn-acao btn-iniciar">ENTRAR</button>
                <button @onclick="Limpar" class="btn-acao btn-parar">LIMPAR</button>
            </div>
        </div>
    </div>
</div>

@if (exibirToken)
{
    <div class="token-debug">
        <p>Token recebido:</p>
        <code style="word-break: break-all;">@token</code>
    </div>
}

<style>
    .login-outer-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
    }

    .login-container {
        display: flex;
        flex-direction: column;
        width: 400px;
        background: linear-gradient(135deg, #e6e6e6 0%, #a6a6a6 100%);
        border: 5px solid #444;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 10px 10px 20px rgba(0,0,0,0.4);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .visor-login {
        background-color: #222;
        color: #0f0;
        min-height: 60px;
        padding: 15px;
        border-radius: 5px;
        margin-bottom: 20px;
        border: 4px solid #111;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .status-tela {
        font-size: 16px;
        font-family: monospace;
        color: #0f0;
    }

    .painel-login {
        background-color: #333;
        padding: 20px;
        border-radius: 10px;
        border: 2px solid #888;
        color: white;
    }

    .form-grupo {
        margin-bottom: 15px;
    }

    .form-grupo label {
        display: block;
        margin-bottom: 5px;
        font-weight: bold;
    }

    .form-control {
        width: 100%;
        padding: 10px;
        border-radius: 5px;
        border: 1px solid #999;
        background: #fff;
        color: #333;
    }

    .acoes-login {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-top: 10px;
    }

    .btn-acao {
        padding: 12px;
        font-weight: bold;
        color: white;
        border: none;
        cursor: pointer;
        border-radius: 5px;
        text-transform: uppercase;
    }

    .btn-iniciar { background-color: #28a745; }
    .btn-parar { background-color: #dc3545; }

    .btn-acao:hover {
        filter: brightness(1.1);
    }

    .token-debug {
        margin: 20px auto;
        max-width: 600px;
        padding: 15px;
        background: #f8f9fa;
        border: 1px solid #ddd;
        border-radius: 5px;
    }
</style>

@code {
    private string usuario = "";
    private string senha = "";
    private string mensagemStatus = "AUTENTICAÇÃO NECESSÁRIA";
    private string token = "";
    private bool exibirToken = false;

    private async Task RealizarLogin()
    {
        try
        {
            var loginData = new { Usuario = usuario, Senha = senha };
            var response = await Http.PostAsJsonAsync("api/Autenticacao/login", loginData);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<JsonElement>();
                token = result.GetProperty("token").GetString() ?? "";
                await Auth.Login(token, JS);
                mensagemStatus = "ACESSO CONCEDIDO!";
                exibirToken = true;
                
                // Redireciona se for sucesso
                await Task.Delay(2000);
                Navigation.NavigateTo("/microondas");
            }
            else
            {
                mensagemStatus = "ACESSO NEGADO!";
            }
        }
        catch (Exception)
        {
            mensagemStatus = "ERRO DE CONEXÃO!";
        }
    }

    private void Limpar()
    {
        usuario = "";
        senha = "";
        mensagemStatus = "AUTENTICAÇÃO NECESSÁRIA";
        exibirToken = false;
    }
}
